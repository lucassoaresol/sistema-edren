generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserProfileCode {
  ADMIN
  MANAGER
  SELLER_OPERATOR
}

enum CollectionStatus {
  ACTIVE
  ARCHIVED
  FUTURE
}

enum StockMovementType {
  INITIAL_ENTRY
  ENTRY
  TRANSFER
  ADJUSTMENT
  CONDITIONAL_OUT
  CONDITIONAL_RETURN
  RESELLER_OUT
  RESELLER_RETURN
}

enum CustomerTypeCode {
  FINAL_CUSTOMER
  RESELLER
}

enum SaleStatus {
  ACTIVE
  CANCELED
}

enum PaymentStatus {
  ACTIVE
  CANCELED
}

enum DiscountType {
  AMOUNT
  PERCENTAGE
}

model UserProfile {
  id          String          @id @default(cuid())
  code        UserProfileCode @unique
  name        String
  description String?
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  users       User[]
}

model User {
  id           String      @id @default(cuid())
  name         String
  username     String      @unique
  passwordHash String
  isActive     Boolean     @default(true)
  profileId    String
  profile      UserProfile @relation(fields: [profileId], references: [id], onDelete: Restrict)
  sessions     Session[]
  stockMovements StockMovement[]
  responsibleSales Sale[] @relation("SaleResponsibleUser")
  canceledSales    Sale[] @relation("SaleCanceledByUser")
  receivedPayments Payment[] @relation("PaymentReceivedByUser")
  canceledPayments Payment[] @relation("PaymentCanceledByUser")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([profileId])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model SizeGrid {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  sizes       Size[]
  products    Product[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Size {
  id        String   @id @default(cuid())
  name      String
  sortOrder Int
  isActive  Boolean  @default(true)
  gridId    String
  grid      SizeGrid @relation(fields: [gridId], references: [id], onDelete: Restrict)
  variants  ProductVariant[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gridId, name])
  @@index([gridId])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    Product[]
}

model Color {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String?  @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  variants  ProductVariant[]
}

model StockLocation {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  balances    StockBalance[]
  movementsFrom StockMovement[] @relation("StockMovementFromLocation")
  movementsTo   StockMovement[] @relation("StockMovementToLocation")
  saleItems   SaleItem[]
}

model Collection {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  status      CollectionStatus @default(ACTIVE)
  products    Product[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Product {
  id           String           @id @default(cuid())
  reference    String           @unique
  name         String
  description  String?
  salePrice    Decimal          @db.Decimal(12, 2)
  cost         Decimal?         @db.Decimal(12, 2)
  isActive     Boolean          @default(true)
  collectionId String
  categoryId   String
  sizeGridId   String
  collection   Collection       @relation(fields: [collectionId], references: [id], onDelete: Restrict)
  category     Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  sizeGrid     SizeGrid         @relation(fields: [sizeGridId], references: [id], onDelete: Restrict)
  images       ProductImage[]
  variants     ProductVariant[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([collectionId])
  @@index([categoryId])
  @@index([sizeGridId])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  publicId  String
  isMain    Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  colorId   String
  sizeId    String
  isActive  Boolean  @default(true)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  color     Color    @relation(fields: [colorId], references: [id], onDelete: Restrict)
  size      Size     @relation(fields: [sizeId], references: [id], onDelete: Restrict)
  balances  StockBalance[]
  movements StockMovement[]
  saleItems SaleItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, colorId, sizeId])
  @@index([productId])
  @@index([colorId])
  @@index([sizeId])
}

model CustomerType {
  id          String           @id @default(cuid())
  code        CustomerTypeCode @unique
  name        String
  description String?
  isActive    Boolean          @default(true)
  customers   Customer[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Customer {
  id           String       @id @default(cuid())
  name         String
  whatsapp     String       @unique
  city         String?
  neighborhood String?
  usualSize    String?
  preferences  String?
  notes        String?
  isCounter    Boolean      @default(false)
  isActive     Boolean      @default(true)
  typeId       String
  type         CustomerType @relation(fields: [typeId], references: [id], onDelete: Restrict)
  movements    StockMovement[]
  sales        Sale[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([typeId])
}

model StockBalance {
  id         String          @id @default(cuid())
  variantId  String
  locationId String
  quantity   Int             @default(0)
  variant    ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Restrict)
  location   StockLocation   @relation(fields: [locationId], references: [id], onDelete: Restrict)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([variantId, locationId])
  @@index([locationId])
}

model StockMovementReason {
  id          String          @id @default(cuid())
  name        String          @unique
  description String?
  isActive    Boolean         @default(true)
  movements   StockMovement[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model StockMovement {
  id             String              @id @default(cuid())
  type           StockMovementType
  variantId      String
  variant        ProductVariant      @relation(fields: [variantId], references: [id], onDelete: Restrict)
  quantity       Int
  fromLocationId String?
  fromLocation   StockLocation?      @relation("StockMovementFromLocation", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocationId   String?
  toLocation     StockLocation?      @relation("StockMovementToLocation", fields: [toLocationId], references: [id], onDelete: Restrict)
  reasonId       String
  reason         StockMovementReason @relation(fields: [reasonId], references: [id], onDelete: Restrict)
  reasonNote     String?
  responsibleId  String
  responsible    User                @relation(fields: [responsibleId], references: [id], onDelete: Restrict)
  customerId     String?
  customer       Customer?           @relation(fields: [customerId], references: [id], onDelete: Restrict)
  occurredAt     DateTime            @default(now())
  createdAt      DateTime            @default(now())

  @@index([variantId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([reasonId])
  @@index([responsibleId])
  @@index([customerId])
}

model SalesChannel {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sales       Sale[]
}

model PaymentMethod {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  payments    Payment[]
}

model Sale {
  id                  String        @id @default(cuid())
  status              SaleStatus    @default(ACTIVE)
  customerId          String
  customer            Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  responsibleUserId   String
  responsibleUser     User          @relation("SaleResponsibleUser", fields: [responsibleUserId], references: [id], onDelete: Restrict)
  salesChannelId      String
  salesChannel        SalesChannel  @relation(fields: [salesChannelId], references: [id], onDelete: Restrict)
  saleDate            DateTime
  grossAmount         Decimal       @db.Decimal(12, 2)
  discountType        DiscountType?
  discountValue       Decimal?      @db.Decimal(12, 2)
  discountReason      String?
  finalAmount         Decimal       @db.Decimal(12, 2)
  openBalanceDueDate  DateTime?
  notes               String?
  cancellationReason  String?
  canceledAt          DateTime?
  canceledById        String?
  canceledBy          User?         @relation("SaleCanceledByUser", fields: [canceledById], references: [id], onDelete: Restrict)
  items               SaleItem[]
  payments            Payment[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@index([customerId])
  @@index([responsibleUserId])
  @@index([salesChannelId])
  @@index([saleDate])
  @@index([status])
  @@index([canceledById])
}

model SaleItem {
  id             String          @id @default(cuid())
  saleId         String
  sale           Sale            @relation(fields: [saleId], references: [id], onDelete: Restrict)
  variantId      String
  variant        ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Restrict)
  originLocationId String
  originLocation   StockLocation @relation(fields: [originLocationId], references: [id], onDelete: Restrict)
  quantity       Int
  unitPrice      Decimal         @db.Decimal(12, 2)
  totalAmount    Decimal         @db.Decimal(12, 2)
  createdAt      DateTime        @default(now())

  @@index([saleId])
  @@index([variantId])
  @@index([originLocationId])
}

model Payment {
  id              String        @id @default(cuid())
  status          PaymentStatus @default(ACTIVE)
  saleId          String
  sale            Sale          @relation(fields: [saleId], references: [id], onDelete: Restrict)
  paymentMethodId String
  paymentMethod   PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict)
  amount          Decimal       @db.Decimal(12, 2)
  paidAt          DateTime      @default(now())
  note            String?
  receivedById    String
  receivedBy      User          @relation("PaymentReceivedByUser", fields: [receivedById], references: [id], onDelete: Restrict)
  canceledAt      DateTime?
  canceledReason  String?
  canceledById    String?
  canceledBy      User?         @relation("PaymentCanceledByUser", fields: [canceledById], references: [id], onDelete: Restrict)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([saleId])
  @@index([paymentMethodId])
  @@index([paidAt])
  @@index([status])
  @@index([receivedById])
  @@index([canceledById])
}
